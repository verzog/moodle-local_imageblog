{{!
    @template local_imageblog/taxonomy_index

    Admin index page for managing one taxonomy type.

    Context variables required for this template:
    * type - taxonomy type identifier
    * rows - array of items with id, name, editurl, deleteurl
    * hasrows - boolean
    * addurl - URL to add a new item
    * tabs - array of {label, url, active}
    * showslug, showcolour, showparent, showorder - column visibility flags

    Example context (json):
    {
        "type": "tag",
        "rows": [],
        "hasrows": false,
        "addurl": "https://moodle.local/local/imageblog/manage.php?type=tag&action=add",
        "tabs": [
            {"label": "Categories", "url": "https://moodle.local/local/imageblog/manage.php?type=category", "active": false},
            {"label": "Tags", "url": "https://moodle.local/local/imageblog/manage.php?type=tag", "active": true}
        ],
        "showslug": true,
        "showcolour": false,
        "showparent": false,
        "showorder": false
    }
}}
<div class="local-imageblog-taxonomy">
    <ul class="nav nav-tabs mb-3" role="tablist">
        {{#tabs}}
            <li class="nav-item">
                <a class="nav-link {{#active}}active{{/active}}" href="{{url}}">{{label}}</a>
            </li>
        {{/tabs}}
    </ul>

    <p>
        <a class="btn btn-primary" href="{{addurl}}">{{#str}}add{{/str}}</a>
    </p>

    {{#hasrows}}
        <table class="generaltable">
            <thead>
                <tr>
                    <th>{{#str}}name{{/str}}</th>
                    {{#showparent}}<th>{{#str}}category, local_imageblog{{/str}}</th>{{/showparent}}
                    {{#showslug}}<th>{{#str}}slug, local_imageblog{{/str}}</th>{{/showslug}}
                    {{#showcolour}}<th>{{#str}}colour, local_imageblog{{/str}}</th>{{/showcolour}}
                    {{#showorder}}<th>{{#str}}sortorder, local_imageblog{{/str}}</th>{{/showorder}}
                    <th>{{#str}}actions{{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#rows}}
                    <tr>
                        <td>{{name}}</td>
                        {{#showparent}}<td>{{parentname}}</td>{{/showparent}}
                        {{#showslug}}<td><code>{{slug}}</code></td>{{/showslug}}
                        {{#showcolour}}<td><span class="badge badge-{{colourkey}}">{{colourkey}}</span></td>{{/showcolour}}
                        {{#showorder}}<td>{{sortorder}}</td>{{/showorder}}
                        <td>
                            <a href="{{editurl}}">{{#str}}edit{{/str}}</a>
                            &middot;
                            <a href="{{deleteurl}}" data-action="delete">{{#str}}delete{{/str}}</a>
                        </td>
                    </tr>
                {{/rows}}
            </tbody>
        </table>
    {{/hasrows}}
    {{^hasrows}}
        <div class="alert alert-info">{{#str}}notaxonomyrows, local_imageblog{{/str}}</div>
    {{/hasrows}}
</div>
