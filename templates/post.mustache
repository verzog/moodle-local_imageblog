{{!
    @template local_imageblog/post

    Single post view.

    Context variables required for this template:
    * id            int
    * title         string
    * body          string  — already passed through format_text()
    * authorname    string
    * datepublished string
    * haspanorama   bool
    * panoramaurl   string
    * listingurl    string
    * lazyimages    bool
    * isdraft       bool
    * statuslabel   string
    * canunpublish  bool
    * unpublishurl  string
    * canedit       bool
    * editurl       string
    * iscase        bool
    * casepanel     object — see case_panel.mustache

    Example context (json):
    {
        "id": 1,
        "title": "Dermoscopy of pigmented lesions",
        "body": "<p>Body content goes here.</p>",
        "authorname": "Jane Doe",
        "datepublished": "1 June 2026",
        "haspanorama": false,
        "panoramaurl": "",
        "listingurl": "https://moodle.local/local/imageblog/index.php",
        "lazyimages": true,
        "isdraft": false,
        "statuslabel": "Published",
        "canunpublish": false,
        "unpublishurl": "",
        "canedit": false,
        "editurl": "",
        "iscase": false,
        "casepanel": null
    }
}}
<div class="local-imageblog-post">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <a href="{{listingurl}}" class="btn btn-sm btn-outline-secondary">
            {{#str}}backtoposts, local_imageblog{{/str}}
        </a>
        <div class="d-flex gap-2 flex-wrap">
            {{#canedit}}
                <a href="{{editurl}}" class="btn btn-sm btn-primary">
                    {{#str}}editpost, local_imageblog{{/str}}
                </a>
            {{/canedit}}
            {{#canunpublish}}
                <a href="{{unpublishurl}}" class="btn btn-sm btn-outline-warning">
                    {{#str}}reverttodraft, local_imageblog{{/str}}
                </a>
            {{/canunpublish}}
        </div>
    </div>

    {{#isdraft}}
        <div class="alert alert-warning">{{statuslabel}}</div>
    {{/isdraft}}

    {{#haspanorama}}
    <div class="local-imageblog-post__panorama mb-3"
         data-region="local-imageblog-panorama"
         data-imgurl="{{panoramaurl}}"
         role="region"
         aria-label="{{#str}}panorama, local_imageblog{{/str}}"></div>
    {{/haspanorama}}

    <h1 class="local-imageblog-post__title mb-2">{{title}}</h1>

    <div class="local-imageblog-post__meta text-muted small mb-3">
        <span>{{authorname}}</span>
        <span aria-hidden="true">·</span>
        <span>{{datepublished}}</span>
    </div>

    <div class="local-imageblog-post-body">
        {{{body}}}
    </div>

    {{#iscase}}
        {{#casepanel}}
            {{> local_imageblog/case_panel }}
        {{/casepanel}}
    {{/iscase}}
</div>
