{{!
    @template local_imageblog/lightbox

    Lightbox dialog injected by the lightbox.js module on the post view page.
    Rendered once on first image click; src and alt are populated by JS as
    the user clicks individual images.

    Context variables required for this template:
    * (none)

    Example context (json):
    {}
}}
<dialog class="local-imageblog-lightbox" aria-label="{{#str}}lightbox_imagepreview, local_imageblog{{/str}}">
    <button type="button" class="local-imageblog-lightbox__close" data-action="close"
            aria-label="{{#str}}close, local_imageblog{{/str}}">&times;</button>
    <figure class="local-imageblog-lightbox__figure">
        <img alt="" data-region="local-imageblog-lightbox__image"
             src="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==">
        <figcaption hidden></figcaption>
    </figure>
</dialog>
