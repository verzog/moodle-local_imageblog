{{!
    @template local_imageblog/listing

    Listing page — filter bar + card grid + pagination.

    Context variables:
    * cards         array  — see card.mustache
    * hascards      bool
    * filterbar     object — authors, categories, subcategories, tags, levels,
                            keyword, datefrom, dateto, formaction
    * pagination    object — show, pages, hasprev, hasnext, prevurl, nexturl
    * cancreate     bool
    * newposturl    string
    * subcatdata    string — JSON map of categoryid -> [{id,name}] for dependent dropdown
}}
<div class="local-imageblog-listing"
     data-region="local-imageblog-filters"
     data-subcats="{{subcatdata}}">

    <div class="local-imageblog-filters card mb-4">
        <div class="card-body">
            <form method="get" action="{{filterbar.formaction}}">
                <div class="row g-2 mb-2">
                    <div class="col-md-3">
                        <label class="form-label small text-muted" for="local-imageblog-filter-cat">{{#str}}category, local_imageblog{{/str}}</label>
                        <select id="local-imageblog-filter-cat" name="categoryid" class="form-select form-select-sm" data-action="category-change">
                            <option value="">{{#str}}selectcategory, local_imageblog{{/str}}</option>
                            {{#filterbar.categories}}
                            <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                            {{/filterbar.categories}}
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted" for="local-imageblog-filter-subcat">{{#str}}subcategory, local_imageblog{{/str}}</label>
                        <select id="local-imageblog-filter-subcat" name="subcategoryid" class="form-select form-select-sm" data-region="subcategory">
                            <option value="">{{#str}}selectsubcategory, local_imageblog{{/str}}</option>
                            {{#filterbar.subcategories}}
                            <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                            {{/filterbar.subcategories}}
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted" for="local-imageblog-filter-tag">{{#str}}tags, local_imageblog{{/str}}</label>
                        <select id="local-imageblog-filter-tag" name="tagid" class="form-select form-select-sm">
                            <option value="">{{#str}}selecttags, local_imageblog{{/str}}</option>
                            {{#filterbar.tags}}
                            <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                            {{/filterbar.tags}}
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted" for="local-imageblog-filter-author">{{#str}}selectauthors, local_imageblog{{/str}}</label>
                        <select id="local-imageblog-filter-author" name="authorid" class="form-select form-select-sm">
                            <option value="">{{#str}}selectauthors, local_imageblog{{/str}}</option>
                            {{#filterbar.authors}}
                            <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                            {{/filterbar.authors}}
                        </select>
                    </div>
                </div>
                <div class="row g-2 mb-2">
                    {{#filterbar.haslevels}}
                    <div class="col-md-3">
                        <label class="form-label small text-muted" for="local-imageblog-filter-level">{{#str}}level, local_imageblog{{/str}}</label>
                        <select id="local-imageblog-filter-level" name="levelid" class="form-select form-select-sm">
                            <option value="">{{#str}}alllevels, local_imageblog{{/str}}</option>
                            {{#filterbar.levels}}
                            <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                            {{/filterbar.levels}}
                        </select>
                    </div>
                    {{/filterbar.haslevels}}
                    <div class="col-md-3">
                        <label class="form-label small text-muted" for="local-imageblog-filter-datefrom">{{#str}}datefrom, local_imageblog{{/str}}</label>
                        <input id="local-imageblog-filter-datefrom" type="date" name="datefrom"
                               class="form-control form-control-sm" value="{{filterbar.datefrom}}">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted" for="local-imageblog-filter-dateto">{{#str}}dateto, local_imageblog{{/str}}</label>
                        <input id="local-imageblog-filter-dateto" type="date" name="dateto"
                               class="form-control form-control-sm" value="{{filterbar.dateto}}">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted" for="local-imageblog-filter-keyword">{{#str}}keyword, local_imageblog{{/str}}</label>
                        <input id="local-imageblog-filter-keyword" type="text" name="keyword"
                               class="form-control form-control-sm"
                               value="{{filterbar.keyword}}">
                    </div>
                    {{#filterbar.showstatus}}
                    <div class="col-md-3">
                        <label class="form-label small text-muted" for="local-imageblog-filter-status">{{#str}}status, local_imageblog{{/str}}</label>
                        <select id="local-imageblog-filter-status" name="status" class="form-select form-select-sm">
                            {{#filterbar.statusoptions}}
                            <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                            {{/filterbar.statusoptions}}
                        </select>
                    </div>
                    {{/filterbar.showstatus}}
                </div>
                <div class="row g-2">
                    <div class="col-12 d-flex justify-content-end gap-2">
                        <button type="submit" class="btn btn-sm btn-primary">
                            {{#str}}searchposts, local_imageblog{{/str}}
                        </button>
                        <a href="{{filterbar.formaction}}" class="btn btn-sm btn-outline-secondary">
                            {{#str}}resetfilters, local_imageblog{{/str}}
                        </a>
                        {{#cancreate}}
                        <a href="{{newposturl}}" class="btn btn-sm btn-success">
                            {{#str}}newpost, local_imageblog{{/str}}
                        </a>
                        {{/cancreate}}
                    </div>
                </div>
            </form>
        </div>
    </div>

    {{#hascards}}
    <div class="local-imageblog-card-grid">
        {{#cards}}
            {{> local_imageblog/card}}
        {{/cards}}
    </div>
    {{/hascards}}
    {{^hascards}}
    <div class="local-imageblog-empty text-center py-5 text-muted">
        <p>{{#str}}nopostsfound, local_imageblog{{/str}}</p>
    </div>
    {{/hascards}}

    {{#pagination.show}}
    <nav class="local-imageblog-pagination d-flex justify-content-center align-items-center gap-1 mt-4"
         aria-label="{{#str}}paginationlabel, local_imageblog{{/str}}">
        {{#pagination.hasprev}}
        <a href="{{pagination.prevurl}}" class="btn btn-sm btn-outline-secondary">
            {{#str}}previous, local_imageblog{{/str}}
        </a>
        {{/pagination.hasprev}}
        {{#pagination.pages}}
        <a href="{{url}}" class="btn btn-sm {{#active}}btn-primary{{/active}}{{^active}}btn-outline-secondary{{/active}}">{{num}}</a>
        {{/pagination.pages}}
        {{#pagination.hasnext}}
        <a href="{{pagination.nexturl}}" class="btn btn-sm btn-outline-secondary">
            {{#str}}next, local_imageblog{{/str}}
        </a>
        {{/pagination.hasnext}}
    </nav>
    {{/pagination.show}}

</div>
{{#js}}
require(['local_imageblog/filter'], function(Filter) {
    Filter.init();
});
{{/js}}
