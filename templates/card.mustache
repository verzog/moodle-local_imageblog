{{!
    Single blog post card — used in the listing grid.

    @template local_scca_blog/card
    @copyright 2026 Skin Cancer College of Australasia
    @license   http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Context variables:
    * id           int
    * viewurl      string
    * title        string
    * summary      string
    * authorname   string
    * datepublished string  — already formatted via userdate() in renderer
    * hasimage     bool
    * imageurl     string
    * tags         array   [{name}]
    * levels       array   [{name, colourkey}]
    * hastags      bool
    * haslevels    bool
}}

<div class="scca-blog-card">
    <a href="{{viewurl}}" class="scca-blog-card__link" tabindex="-1" aria-hidden="true">
        {{#hasimage}}
        <img src="{{imageurl}}"
             alt=""
             class="scca-blog-card__image"
             loading="eager"
             width="800" height="530">
        {{/hasimage}}
        {{^hasimage}}
        <div class="scca-blog-card__image scca-blog-card__image--placeholder" aria-hidden="true"></div>
        {{/hasimage}}
    </a>

    <div class="scca-blog-card__body">

        <div class="scca-blog-card__meta">
            <span class="scca-blog-card__date">{{datepublished}}</span>
            <span class="scca-blog-card__author">{{authorname}}</span>
        </div>

        <h2 class="scca-blog-card__title">
            <a href="{{viewurl}}">{{title}}</a>
        </h2>

        {{#summary}}
        <p class="scca-blog-card__summary">{{summary}}</p>
        {{/summary}}

        {{#haslevels}}
        <div class="scca-blog-card__levels" aria-label="{{#str}}levels, local_scca_blog{{/str}}">
            {{#levels}}
            <span class="scca-blog-badge scca-blog-badge--{{colourkey}}">{{name}}</span>
            {{/levels}}
        </div>
        {{/haslevels}}

        {{#hastags}}
        <div class="scca-blog-card__tags" aria-label="{{#str}}tags, local_scca_blog{{/str}}">
            {{#tags}}
            <span class="scca-blog-badge scca-blog-badge--tag">{{name}}</span>
            {{/tags}}
        </div>
        {{/hastags}}

    </div>
</div>
