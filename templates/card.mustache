{{!
    @template local_imageblog/card

    Single blog post card — used in the listing grid.

    Context variables:
    * id            int
    * viewurl       string
    * title         string
    * summary       string
    * authorname    string
    * datepublished string
    * hasimage      bool
    * imageurl      string
    * tags          array  [{name}]
    * levels        array  [{name, colourkey}]
    * hastags       bool
    * haslevels     bool
}}
<article class="local-imageblog-card">
    <a href="{{viewurl}}" class="local-imageblog-card__link" tabindex="-1" aria-hidden="true">
        {{#hasimage}}
        <img src="{{imageurl}}" alt=""
             class="local-imageblog-card__image"
             loading="lazy" width="800" height="530">
        {{/hasimage}}
        {{^hasimage}}
        <div class="local-imageblog-card__image local-imageblog-card__image--placeholder" aria-hidden="true"></div>
        {{/hasimage}}
    </a>

    <div class="local-imageblog-card__body">
        <div class="local-imageblog-card__meta">
            <span class="local-imageblog-card__date">{{datepublished}}</span>
            <span class="local-imageblog-card__author">{{authorname}}</span>
        </div>

        <h2 class="local-imageblog-card__title">
            <a href="{{viewurl}}">{{title}}</a>
        </h2>

        {{#summary}}
        <p class="local-imageblog-card__summary">{{summary}}</p>
        {{/summary}}

        {{#haslevels}}
        <div class="local-imageblog-card__levels" aria-label="{{#str}}levels, local_imageblog{{/str}}">
            {{#levels}}
            <span class="local-imageblog-badge local-imageblog-badge--{{colourkey}}">{{name}}</span>
            {{/levels}}
        </div>
        {{/haslevels}}

        {{#hastags}}
        <div class="local-imageblog-card__tags" aria-label="{{#str}}tags, local_imageblog{{/str}}">
            {{#tags}}
            <span class="local-imageblog-badge local-imageblog-badge--tag">{{name}}</span>
            {{/tags}}
        </div>
        {{/hastags}}
    </div>
</article>
