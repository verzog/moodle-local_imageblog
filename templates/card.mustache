{{!
    @template local_imageblog/card

    Single blog post card — used in the listing grid.

    Context variables required for this template:
    * id            int
    * viewurl       string
    * title         string
    * summary       string
    * authorname    string
    * datepublished string
    * hasimage      bool
    * imageurl      string
    * tags          array  [{name}]
    * levels        array  [{name, colourkey}]
    * hastags       bool
    * haslevels     bool
    * isdraft       bool
    * isarchived    bool
    * statuslabel   string
    * canedit       bool
    * editurl       string

    Example context (json):
    {
        "id": 1,
        "viewurl": "https://moodle.local/local/imageblog/view.php?id=1",
        "title": "Dermoscopy of pigmented lesions",
        "summary": "A short visual summary",
        "authorname": "Jane Doe",
        "datepublished": "1 June 2026",
        "hasimage": true,
        "imageurl": "https://moodle.local/pluginfile.php/1/local_imageblog/featured_image/1/example.jpg",
        "tags": [{"name": "dermoscopy"}, {"name": "screening"}],
        "levels": [{"name": "Beginner", "colourkey": "teal"}],
        "hastags": true,
        "haslevels": true,
        "isdraft": false,
        "isarchived": false,
        "statuslabel": "",
        "canedit": true,
        "editurl": "https://moodle.local/local/imageblog/edit.php?id=1"
    }
}}
<article class="local-imageblog-card">
    <a href="{{viewurl}}" class="local-imageblog-card__link" tabindex="-1" aria-hidden="true">
        {{#hasimage}}
        <img src="{{imageurl}}" alt=""
             class="local-imageblog-card__image"
             loading="lazy" width="800" height="530">
        {{/hasimage}}
        {{^hasimage}}
        <div class="local-imageblog-card__image local-imageblog-card__image--placeholder" aria-hidden="true"></div>
        {{/hasimage}}
    </a>

    <div class="local-imageblog-card__body">
        <div class="local-imageblog-card__meta">
            <span class="local-imageblog-card__date">{{datepublished}}</span>
            <span class="local-imageblog-card__author">{{authorname}}</span>
        </div>

        <h2 class="local-imageblog-card__title">
            <a href="{{viewurl}}">{{title}}</a>
            {{#isdraft}}
            <span class="badge bg-warning text-dark ms-1 align-middle">{{statuslabel}}</span>
            {{/isdraft}}
            {{#isarchived}}
            <span class="badge bg-secondary ms-1 align-middle">{{statuslabel}}</span>
            {{/isarchived}}
        </h2>

        {{#summary}}
        <p class="local-imageblog-card__summary">{{summary}}</p>
        {{/summary}}

        {{#haslevels}}
        <div class="local-imageblog-card__levels" aria-label="{{#str}}levels, local_imageblog{{/str}}">
            {{#levels}}
            <span class="local-imageblog-badge local-imageblog-badge--{{colourkey}}">{{name}}</span>
            {{/levels}}
        </div>
        {{/haslevels}}

        {{#hastags}}
        <div class="local-imageblog-card__tags" aria-label="{{#str}}tags, local_imageblog{{/str}}">
            {{#tags}}
            <span class="local-imageblog-badge local-imageblog-badge--tag">{{name}}</span>
            {{/tags}}
        </div>
        {{/hastags}}

        {{#canedit}}
        <div class="local-imageblog-card__actions mt-2">
            <a href="{{editurl}}" class="btn btn-sm btn-outline-primary">
                {{#str}}editpost, local_imageblog{{/str}}
            </a>
        </div>
        {{/canedit}}
    </div>
</article>
